{
  "name": "apex-grid",
  "version": "0.0.0",
  "description": "Web component data grid following open-wc recommendations",
  "keywords": [
    "lit",
    "web-component",
    "lit-element"
  ],
  "license": "SEE LICENSE IN LICENSE.md",
  "author": "apex-grid",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    },
    "./define": {
      "types": "./define.d.ts",
      "default": "./define.js"
    },
    "./internal": {
      "types": "./internal/index.d.ts",
      "default": "./internal/index.js"
    },
    "./styles.css": "./styles.css"
  },
  "type": "module",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/apexcharts/apex-grid.git"
  },
  "bugs": {
    "url": "https://github.com/apexcharts/apex-grid/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "customElements": "custom-elements.json",
  "dependencies": {
    "@lit-labs/virtualizer": "~2.1.0",
    "@lit/context": "~1.1.5",
    "igniteui-webcomponents": "~6.1.0",
    "lit": "^3.3.0"
  }
}